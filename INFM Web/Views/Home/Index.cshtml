@{
    ViewData["Title"] = "Home";
    var isStaff = User.IsInRole("Admin") || User.IsInRole("Worker");
}

<div class="p-5 mb-4 bg-body-tertiary rounded-3 text-center">
    <h1 class="display-5 fw-bold">Inventory Management System</h1>
    <p class="col-lg-8 mx-auto fs-5 text-muted">
        Track products, suppliers and stock across every warehouse from one place.
    </p>
    <div class="d-inline-flex gap-2 mt-2">
        @if (isStaff)
        {
            <a asp-controller="Home" asp-action="Dash" class="btn btn-primary btn-lg">Go to Dashboard</a>
        }
        else if (User.Identity != null && User.Identity.IsAuthenticated)
        {
            <a asp-area="Identity" asp-page="/Account/Manage/Index" class="btn btn-primary btn-lg">My Profile</a>
        }
        else
        {
            <a asp-area="Identity" asp-page="/Account/Login" class="btn btn-primary btn-lg">Login</a>
        }
    </div>
</div>

<div class="row g-4">
    <div class="col-md-4">
        <div class="card h-100">
            <div class="card-body">
                <h2 class="h5">Product Management</h2>
                <p class="text-muted mb-0">Maintain your catalogue with SKUs, pricing and reorder levels.</p>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card h-100">
            <div class="card-body">
                <h2 class="h5">Warehouse Stock</h2>
                <p class="text-muted mb-0">See how much of each product sits in every warehouse.</p>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card h-100">
            <div class="card-body">
                <h2 class="h5">Supplier Tracking</h2>
                <p class="text-muted mb-0">Keep supplier details and contacts close to the products they supply.</p>
            </div>
        </div>
    </div>
</div>
