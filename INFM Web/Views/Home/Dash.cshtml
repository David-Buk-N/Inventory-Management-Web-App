@model INFM_Web.Models.DTOs.DashboardViewModel

@{
    ViewData["Title"] = "Dashboard";
    var isAdmin = User.IsInRole("Admin");
}

<h1 class="mt-3">Inventory Dashboard</h1>
<hr />

<div class="row g-3 mb-4">
    <div class="col-md-3">
        <div class="card text-bg-light h-100">
            <div class="card-body">
                <h6 class="card-subtitle text-muted">Products</h6>
                <p class="display-6 mb-0">@Model.ProductCount</p>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card text-bg-light h-100">
            <div class="card-body">
                <h6 class="card-subtitle text-muted">Warehouses</h6>
                <p class="display-6 mb-0">@Model.WarehouseCount</p>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card text-bg-light h-100">
            <div class="card-body">
                <h6 class="card-subtitle text-muted">Units On Hand</h6>
                <p class="display-6 mb-0">@Model.TotalUnitsOnHand</p>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card @(Model.LowStockCount > 0 ? "text-bg-warning" : "text-bg-light") h-100">
            <div class="card-body">
                <h6 class="card-subtitle @(Model.LowStockCount > 0 ? "" : "text-muted")">Low-Stock Products</h6>
                <p class="display-6 mb-0">@Model.LowStockCount</p>
            </div>
        </div>
    </div>
</div>

<div class="d-flex flex-wrap gap-2">
    <a asp-controller="Stock" asp-action="Index" class="btn btn-primary">View Stock</a>
    <a asp-controller="Stock" asp-action="Create" class="btn btn-outline-primary">Assign Stock</a>
    <a asp-controller="Stock" asp-action="Index" asp-route-lowStockOnly="true" class="btn btn-outline-warning">Low Stock</a>
    <a asp-controller="Products" asp-action="Index" class="btn btn-outline-secondary">Products</a>
    @if (isAdmin)
    {
        <a asp-controller="Warehouses" asp-action="Index" class="btn btn-outline-secondary">Warehouses</a>
        <a asp-controller="Suppliers" asp-action="Index" class="btn btn-outline-secondary">Suppliers</a>
    }
</div>
