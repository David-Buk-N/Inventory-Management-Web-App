@model IEnumerable<INFM_Web.Models.Product>

@{
    ViewData["Title"] = "Products";
    var isAdmin = User.IsInRole("Admin");
}

<div class="d-flex justify-content-between align-items-center mt-3">
    <h1>Products</h1>
    @if (isAdmin)
    {
        <a asp-action="Create" class="btn btn-primary">+ New Product</a>
    }
</div>
<hr />

@if (!Model.Any())
{
    <div class="alert alert-info">No products yet.</div>
}
else
{
    <table class="table table-hover">
        <thead>
            <tr>
                <th>@Html.DisplayNameFor(model => model.SKU)</th>
                <th>@Html.DisplayNameFor(model => model.Product_Name)</th>
                <th>Category</th>
                <th>Supplier</th>
                <th class="text-end">@Html.DisplayNameFor(model => model.Product_Price)</th>
                <th class="text-end">Total Stock</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr class="@(item.IsLowStock ? "table-warning" : "")">
                    <td>@item.SKU</td>
                    <td>@item.Product_Name</td>
                    <td>@item.Category?.CategoryName</td>
                    <td>@item.Supplier?.SupplierName</td>
                    <td class="text-end">@item.Product_Price.ToString("C")</td>
                    <td class="text-end">
                        @item.TotalStock
                        @if (item.IsLowStock)
                        {
                            <span class="badge text-bg-danger">Low</span>
                        }
                    </td>
                    <td class="text-end">
                        <a asp-action="Details" asp-route-id="@item.Product_Id">Details</a>
                        @if (isAdmin)
                        {
                            <text> | </text>
                            <a asp-action="Edit" asp-route-id="@item.Product_Id">Edit</a>
                            <text> | </text>
                            <a asp-action="Delete" asp-route-id="@item.Product_Id" class="text-danger">Delete</a>
                        }
                    </td>
                </tr>
            }
        </tbody>
    </table>
}
