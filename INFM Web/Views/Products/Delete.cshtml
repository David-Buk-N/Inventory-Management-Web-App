@model INFM_Web.Models.Product

@{
    ViewData["Title"] = "Delete Product";
}

<h1 class="text-danger">Delete Product</h1>
<h4>Are you sure you want to delete this product?</h4>
<hr />

<dl class="row">
    <dt class="col-sm-3">@Html.DisplayNameFor(m => m.Product_Name)</dt>
    <dd class="col-sm-9">@Model.Product_Name</dd>
    <dt class="col-sm-3">@Html.DisplayNameFor(m => m.SKU)</dt>
    <dd class="col-sm-9">@Model.SKU</dd>
    <dt class="col-sm-3">Category</dt>
    <dd class="col-sm-9">@Model.Category?.CategoryName</dd>
    <dt class="col-sm-3">Supplier</dt>
    <dd class="col-sm-9">@Model.Supplier?.SupplierName</dd>
</dl>

<form asp-action="Delete">
    <input type="hidden" asp-for="Product_Id" />
    <input type="submit" value="Delete" class="btn btn-danger" />
    <a asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
</form>
