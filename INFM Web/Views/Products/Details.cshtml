@model INFM_Web.Models.Product

@{
    ViewData["Title"] = "Product Details";
}

<div class="d-flex justify-content-between align-items-center mt-3">
    <h1>@Model.Product_Name</h1>
    <div>
        @if (User.IsInRole("Admin"))
        {
            <a asp-action="Edit" asp-route-id="@Model.Product_Id" class="btn btn-outline-primary">Edit</a>
        }
        <a asp-action="Index" class="btn btn-outline-secondary">Back</a>
    </div>
</div>
<hr />

<dl class="row">
    <dt class="col-sm-3">@Html.DisplayNameFor(m => m.SKU)</dt>
    <dd class="col-sm-9">@Model.SKU</dd>
    <dt class="col-sm-3">@Html.DisplayNameFor(m => m.Product_Price)</dt>
    <dd class="col-sm-9">@Model.Product_Price.ToString("C")</dd>
    <dt class="col-sm-3">@Html.DisplayNameFor(m => m.ProductDescription)</dt>
    <dd class="col-sm-9">@Model.ProductDescription</dd>
    <dt class="col-sm-3">Category</dt>
    <dd class="col-sm-9">@Model.Category?.CategoryName</dd>
    <dt class="col-sm-3">Supplier</dt>
    <dd class="col-sm-9">@Model.Supplier?.SupplierName</dd>
    <dt class="col-sm-3">@Html.DisplayNameFor(m => m.ReorderLevel)</dt>
    <dd class="col-sm-9">@Model.ReorderLevel</dd>
    <dt class="col-sm-3">@Html.DisplayNameFor(m => m.TotalStock)</dt>
    <dd class="col-sm-9">
        @Model.TotalStock
        @if (Model.IsLowStock)
        {
            <span class="badge text-bg-danger">Low stock</span>
        }
    </dd>
</dl>

<h4 class="mt-4">Stock by warehouse</h4>
@if (Model.Stocks == null || !Model.Stocks.Any())
{
    <div class="alert alert-info">
        Not stocked in any warehouse yet.
        <a asp-controller="Stock" asp-action="Create">Assign stock</a>.
    </div>
}
else
{
    <table class="table">
        <thead>
            <tr>
                <th>Warehouse</th>
                <th class="text-end">Quantity</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var stock in Model.Stocks)
            {
                <tr>
                    <td>@stock.Warehouse?.WarehouseName <span class="text-muted">(@stock.Warehouse?.Code)</span></td>
                    <td class="text-end">@stock.Quantity</td>
                </tr>
            }
        </tbody>
    </table>
}
