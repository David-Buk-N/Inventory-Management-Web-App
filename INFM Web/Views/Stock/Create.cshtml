@model INFM_Web.Models.Stock

@{
    ViewData["Title"] = "Assign Stock";
    var products = ViewBag.Products as SelectList;
    var warehouses = ViewBag.Warehouses as SelectList;
}

<h1>Assign Stock to a Warehouse</h1>
<hr />
<div class="row">
    <div class="col-md-5">
        <form asp-action="Create">
            <div asp-validation-summary="All" class="text-danger"></div>
            <div class="form-group mb-2">
                <label asp-for="Product_Id" class="control-label"></label>
                <select asp-for="Product_Id" class="form-select" asp-items="products">
                    <option value="">-- Select product --</option>
                </select>
                <span asp-validation-for="Product_Id" class="text-danger"></span>
            </div>
            <div class="form-group mb-2">
                <label asp-for="Warehouse_Id" class="control-label"></label>
                <select asp-for="Warehouse_Id" class="form-select" asp-items="warehouses">
                    <option value="">-- Select warehouse --</option>
                </select>
                <span asp-validation-for="Warehouse_Id" class="text-danger"></span>
            </div>
            <div class="form-group mb-3">
                <label asp-for="Quantity" class="control-label"></label>
                <input asp-for="Quantity" class="form-control" />
                <span asp-validation-for="Quantity" class="text-danger"></span>
            </div>
            <div class="form-group">
                <input type="submit" value="Assign" class="btn btn-primary" />
                <a asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
