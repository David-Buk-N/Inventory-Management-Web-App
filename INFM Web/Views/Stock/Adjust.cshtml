@model INFM_Web.Models.DTOs.StockAdjustViewModel

@{
    ViewData["Title"] = "Adjust Stock";
}

<h1>Adjust Stock</h1>
<hr />
<div class="row">
    <div class="col-md-5">
        <dl class="row">
            <dt class="col-sm-5">Product</dt>
            <dd class="col-sm-7">@Model.ProductName</dd>
            <dt class="col-sm-5">Warehouse</dt>
            <dd class="col-sm-7">@Model.WarehouseName</dd>
            <dt class="col-sm-5">On hand</dt>
            <dd class="col-sm-7"><strong>@Model.CurrentQuantity</strong></dd>
        </dl>

        <form asp-action="Adjust">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <input type="hidden" asp-for="Stock_Id" />
            <div class="form-group mb-2">
                <label asp-for="Change" class="control-label"></label>
                <input asp-for="Change" class="form-control" placeholder="e.g. 25 to receive, -10 to issue" />
                <span asp-validation-for="Change" class="text-danger"></span>
            </div>
            <div class="form-group mb-3">
                <label asp-for="Note" class="control-label"></label>
                <input asp-for="Note" class="form-control" />
            </div>
            <div class="form-group">
                <input type="submit" value="Apply" class="btn btn-primary" />
                <a asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
