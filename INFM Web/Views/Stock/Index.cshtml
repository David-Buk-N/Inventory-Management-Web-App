@model IEnumerable<INFM_Web.Models.Stock>

@{
    ViewData["Title"] = "Stock Levels";
    var warehouses = ViewBag.Warehouses as SelectList;
    var products = ViewBag.Products as SelectList;
    bool lowStockOnly = ViewBag.LowStockOnly ?? false;
}

<div class="d-flex justify-content-between align-items-center mt-3">
    <h1>Stock Levels</h1>
    <a asp-action="Create" class="btn btn-primary">+ Assign Stock</a>
</div>
<hr />

<form asp-action="Index" method="get" class="row g-2 align-items-end mb-3">
    <div class="col-auto">
        <label class="form-label">Warehouse</label>
        <select name="warehouseId" class="form-select" asp-items="warehouses">
            <option value="">All warehouses</option>
        </select>
    </div>
    <div class="col-auto">
        <label class="form-label">Product</label>
        <select name="productId" class="form-select" asp-items="products">
            <option value="">All products</option>
        </select>
    </div>
    <div class="col-auto">
        <div class="form-check">
            <input class="form-check-input" type="checkbox" name="lowStockOnly" value="true" id="lowStockOnly" @(lowStockOnly ? "checked" : "") />
            <label class="form-check-label" for="lowStockOnly">Low stock only</label>
        </div>
    </div>
    <div class="col-auto">
        <button type="submit" class="btn btn-outline-secondary">Filter</button>
        <a asp-action="Index" class="btn btn-link">Reset</a>
    </div>
</form>

@if (!Model.Any())
{
    <div class="alert alert-info">No stock records match. Use <strong>Assign Stock</strong> to place a product in a warehouse.</div>
}
else
{
    <table class="table table-hover">
        <thead>
            <tr>
                <th>Product</th>
                <th>Warehouse</th>
                <th class="text-end">Quantity</th>
                <th class="text-end">Reorder Level</th>
                <th>Status</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                var low = item.Product != null && item.Quantity <= item.Product.ReorderLevel;
                <tr class="@(low ? "table-warning" : "")">
                    <td>@item.Product?.Product_Name</td>
                    <td>@item.Warehouse?.WarehouseName <span class="text-muted">(@item.Warehouse?.Code)</span></td>
                    <td class="text-end">@item.Quantity</td>
                    <td class="text-end">@item.Product?.ReorderLevel</td>
                    <td>
                        @if (low)
                        {
                            <span class="badge text-bg-danger">Low</span>
                        }
                        else
                        {
                            <span class="badge text-bg-success">OK</span>
                        }
                    </td>
                    <td class="text-end">
                        <a asp-action="Adjust" asp-route-id="@item.Stock_Id">Adjust</a>
                        @if (User.IsInRole("Admin"))
                        {
                            <text> | </text>
                            <a asp-action="Delete" asp-route-id="@item.Stock_Id" class="text-danger">Delete</a>
                        }
                    </td>
                </tr>
            }
        </tbody>
    </table>
}
