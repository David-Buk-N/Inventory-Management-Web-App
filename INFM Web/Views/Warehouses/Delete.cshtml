@model INFM_Web.Models.Warehouse

@{
    ViewData["Title"] = "Delete Warehouse";
}

<h1 class="text-danger">Delete Warehouse</h1>
<h4>Are you sure you want to delete this warehouse?</h4>
<hr />

@if (Model.Stocks != null && Model.Stocks.Any())
{
    <div class="alert alert-warning">
        This warehouse holds <strong>@Model.UnitsOnHand units</strong> across
        @Model.Stocks.Count() product(s). Deleting it will remove those stock records.
    </div>
}

<dl class="row">
    <dt class="col-sm-3">@Html.DisplayNameFor(m => m.WarehouseName)</dt>
    <dd class="col-sm-9">@Model.WarehouseName</dd>
    <dt class="col-sm-3">Code</dt>
    <dd class="col-sm-9">@Model.Code</dd>
    <dt class="col-sm-3">@Html.DisplayNameFor(m => m.Location)</dt>
    <dd class="col-sm-9">@Model.Location, @Model.City</dd>
</dl>

<form asp-action="Delete">
    <input type="hidden" asp-for="Warehouse_Id" />
    <input type="submit" value="Delete" class="btn btn-danger" />
    <a asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
</form>
