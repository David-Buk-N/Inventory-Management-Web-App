@model INFM_Web.Models.Warehouse

@{
    ViewData["Title"] = "Warehouse Details";
}

<div class="d-flex justify-content-between align-items-center mt-3">
    <h1>@Model.WarehouseName <span class="badge text-bg-secondary">@Model.Code</span></h1>
    <div>
        <a asp-action="Edit" asp-route-id="@Model.Warehouse_Id" class="btn btn-outline-primary">Edit</a>
        <a asp-action="Index" class="btn btn-outline-secondary">Back</a>
    </div>
</div>
<hr />

<dl class="row">
    <dt class="col-sm-3">@Html.DisplayNameFor(m => m.Location)</dt>
    <dd class="col-sm-9">@Model.Location, @Model.City</dd>
    <dt class="col-sm-3">@Html.DisplayNameFor(m => m.Capacity)</dt>
    <dd class="col-sm-9">@Model.Capacity</dd>
    <dt class="col-sm-3">@Html.DisplayNameFor(m => m.UnitsOnHand)</dt>
    <dd class="col-sm-9">@Model.UnitsOnHand</dd>
    <dt class="col-sm-3">@Html.DisplayNameFor(m => m.CreatedDate)</dt>
    <dd class="col-sm-9">@Model.CreatedDate.ToString("yyyy-MM-dd")</dd>
</dl>

<h4 class="mt-4">Stock in this warehouse</h4>
@if (Model.Stocks == null || !Model.Stocks.Any())
{
    <div class="alert alert-info">No stock recorded in this warehouse.</div>
}
else
{
    <table class="table">
        <thead>
            <tr>
                <th>Product</th>
                <th class="text-end">Quantity</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var stock in Model.Stocks)
            {
                <tr>
                    <td>@stock.Product?.Product_Name</td>
                    <td class="text-end">@stock.Quantity</td>
                </tr>
            }
        </tbody>
    </table>
}
